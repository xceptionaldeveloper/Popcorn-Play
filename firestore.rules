rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. GLOBAL SAFETY NET: Default catch-all deny rule
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. GLOBAL HELPERS
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Administrator Check: Bootstrapped securely using the verified user email
    function isAdmin() {
      return isSignedIn() && 'email' in request.auth.token && (
        request.auth.token.email == "mdikhlas098@gmail.com" ||
        request.auth.token.email == "admin@popcornplay.com" ||
        (exists(/databases/$(database)/documents/app_settings/config) && 
         request.auth.token.email == get(/databases/$(database)/documents/app_settings/config).data.get('adminEmail', ''))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isLocalUser(id) {
      return id is string && id.size() >= 10 && id.matches('^local-usr-.*');
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. SCHEMA INTEGRITY VALIDATION BUILDERS
    function isValidUserProfile(data) {
      return (!data.keys().hasAny(['uid']) || data.uid is string)
          && (!data.keys().hasAny(['name']) || (data.name is string && data.name.size() <= 100))
          && (!data.keys().hasAny(['email']) || (data.email is string && data.email.size() <= 100))
          && (!data.keys().hasAny(['isPremium']) || data.isPremium is bool)
          && (!data.keys().hasAny(['favorites']) || data.favorites is list);
    }

    function isValidAppSettings(data) {
      return (!data.keys().hasAny(['appName']) || (data.appName is string && data.appName.size() <= 100))
          && (!data.keys().hasAny(['adultPin']) || (data.adultPin is string && data.adultPin.size() <= 10))
          && (!data.keys().hasAny(['supportActive']) || data.supportActive is bool)
          && (!data.keys().hasAny(['bkash']) || data.bkash is string)
          && (!data.keys().hasAny(['nagad']) || data.nagad is string)
          && (!data.keys().hasAny(['bank']) || data.bank is string);
    }

    function isValidContentItem(data) {
      return (!data.keys().hasAny(['id']) || data.id is string)
          && (!data.keys().hasAny(['title']) || (data.title is string && data.title.size() <= 128))
          && (!data.keys().hasAny(['coverUrl']) || data.coverUrl is string)
          && (!data.keys().hasAny(['videoUrl']) || data.videoUrl is string)
          && (!data.keys().hasAny(['tags']) || data.tags is list)
          && (!data.keys().hasAny(['category']) || data.category is string)
          && (!data.keys().hasAny(['isPremium']) || data.isPremium is bool)
          && (!data.keys().hasAny(['isAdult']) || data.isAdult is bool)
          && (!data.keys().hasAny(['schedule']) || data.schedule is string)
          && (!data.keys().hasAny(['description']) || data.description is string)
          && (!data.keys().hasAny(['rating']) || (data.rating is int || data.rating is float));
    }

    function isValidPaymentRequest(data) {
      return (!data.keys().hasAny(['id']) || data.id is string)
          && (!data.keys().hasAny(['userId']) || data.userId is string)
          && (!data.keys().hasAny(['userName']) || data.userName is string)
          && (!data.keys().hasAny(['userEmail']) || data.userEmail is string)
          && (!data.keys().hasAny(['method']) || data.method is string)
          && (!data.keys().hasAny(['senderNumber']) || (data.senderNumber is string && data.senderNumber.size() <= 100))
          && (!data.keys().hasAny(['transactionId']) || (data.transactionId is string && data.transactionId.size() <= 200))
          && (!data.keys().hasAny(['amount']) || (data.amount is int || data.amount is float))
          && (!data.keys().hasAny(['timestamp']) || data.timestamp is string)
          && (!data.keys().hasAny(['status']) || (data.status is string && data.status in ['pending', 'approved', 'rejected']));
    }

    function isValidNotificationItem(data) {
      return (!data.keys().hasAny(['id']) || data.id is string)
          && (!data.keys().hasAny(['msg']) || (data.msg is string && data.msg.size() <= 1000))
          && (!data.keys().hasAny(['time']) || data.time is string);
    }

    // Support Session checking inside helper
    function isValidSupportSession(data) {
      return data.keys().hasAll(['messages'])
          && (!data.keys().hasAny(['userId']) || data.userId is string)
          && (!data.keys().hasAny(['userName']) || data.userName is string)
          && (!data.keys().hasAny(['userEmail']) || data.userEmail is string)
          && data.messages is list
          && (!data.keys().hasAny(['lastUpdated']) || data.lastUpdated is string);
    }

    // 4. COLLECTION ROUTING & ACTIONS
    
    // User Profiles
    match /users/{userId} {
      allow get: if (isSignedIn() && (isOwner(userId) || isAdmin())) || isLocalUser(userId);
      allow create: if ( (isSignedIn() && isOwner(userId)) || isLocalUser(userId) ) 
                     && incoming().keys().hasAll(['uid', 'name', 'email', 'isPremium', 'favorites']) 
                     && isValidUserProfile(incoming()) 
                     && (incoming().isPremium == false || isAdmin()) 
                     && (!incoming().keys().hasAny(['isAdmin']) || incoming().isAdmin == false || isAdmin());
      allow update: if isValidUserProfile(incoming()) && (
                       isAdmin() || 
                       (isLocalUser(userId) && (
                         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'favorites', 'pinVerified', 'password', 'watchHistory', 'parentalEnabled']) ||
                         (existing().isPremium == true && incoming().isPremium == false && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'favorites', 'pinVerified', 'password', 'watchHistory', 'parentalEnabled', 'isPremium', 'premiumUntil']))
                       )) ||
                       (isSignedIn() && isOwner(userId) && (
                         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'favorites', 'pinVerified', 'password', 'watchHistory', 'parentalEnabled']) ||
                         (existing().isPremium == true && incoming().isPremium == false && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'favorites', 'pinVerified', 'password', 'watchHistory', 'parentalEnabled', 'isPremium', 'premiumUntil']))
                       ))
                     );
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }

    // Global Brand Configuration
    match /app_settings/{documentId} {
      allow get, list: if true;
      allow create: if isAdmin() && incoming().keys().hasAll(['appName', 'adultPin', 'supportActive', 'bkash', 'nagad', 'bank']) && isValidAppSettings(incoming());
      allow update: if isAdmin() && isValidAppSettings(incoming());
      allow delete: if isAdmin();
    }

    // Media Catalog items
    match /content/{contentId} {
      allow get, list: if true;
      allow create, delete: if isAdmin() && isValidContentItem(incoming()) && isValidId(contentId);
      allow update: if (isValidContentItem(incoming()) && isAdmin()) || (
                      incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'ratingCount', 'ratingSum']) &&
                      (!incoming().keys().hasAny(['rating']) || (incoming().rating is int || incoming().rating is float)) &&
                      (!incoming().keys().hasAny(['ratingCount']) || (incoming().ratingCount is int || incoming().ratingCount is float)) &&
                      (!incoming().keys().hasAny(['ratingSum']) || (incoming().ratingSum is int || incoming().ratingSum is float))
                    );

      match /ratings/{userId} {
        allow read: if true;
        allow write: if ((isSignedIn() && isOwner(userId)) || isLocalUser(userId)) &&
                       incoming().keys().hasAll(['userId', 'rating', 'timestamp']) &&
                       incoming().userId == userId &&
                       (incoming().rating is int || incoming().rating is float) &&
                       incoming().rating >= 1 &&
                       incoming().rating <= 5 &&
                       (incoming().timestamp is int || incoming().timestamp is float);
      }
    }

    // Billing Subscriptions
    match /payments/{paymentId} {
      allow get: if (isSignedIn() && (isOwner(existing().userId) || isAdmin())) || isLocalUser(existing().userId);
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid) || isLocalUser(resource.data.userId);
      allow create: if ( (isSignedIn() && (isOwner(incoming().userId) || isAdmin())) || isLocalUser(incoming().userId) ) 
                     && incoming().status == 'pending' 
                     && isValidPaymentRequest(incoming()) 
                     && isValidId(paymentId);
      allow update: if isValidPaymentRequest(incoming()) && isAdmin();
      allow delete: if isAdmin();
    }

    // Broadcaster notifications
    match /notifications/{notificationId} {
      allow get, list: if true;
      allow write: if isAdmin() && isValidNotificationItem(incoming()) && isValidId(notificationId);
    }

    // Noticeboard Notices
    match /notices/{noticeId} {
      allow get, list: if true;
      allow write: if isAdmin() && isValidId(noticeId);
    }

    // Live Support Customer Help-desks
    match /live_support/{userId} {
      allow get: if (isSignedIn() && (isOwner(userId) || isAdmin())) || isLocalUser(userId);
      allow list: if isAdmin();
      allow create: if ( (isSignedIn() && isOwner(userId)) || isLocalUser(userId) ) && isValidSupportSession(incoming()) && isValidId(userId);
      allow update: if ( (isSignedIn() && isOwner(userId)) || isLocalUser(userId) || isAdmin() ) && isValidSupportSession(incoming());
      allow delete: if (isSignedIn() && (isOwner(userId) || isAdmin())) || isLocalUser(userId);
    }

  }
}
