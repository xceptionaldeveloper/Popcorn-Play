rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. GLOBAL SAFETY NET: Default catch-all deny rule
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. GLOBAL HELPERS
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Administrator Check: Bootstrapped securely using the verified user email
    function isAdmin() {
      return isSignedIn() && (
        ('email' in request.auth.token && (
          request.auth.token.email == 'mdikhlas098@gmail.com' ||
          request.auth.token.email == 'mypassion9182@gmail.com' ||
          request.auth.token.email == 'admin@popcornplay.com' ||
          request.auth.token.email == 'Mdikhlas098@gmail.com' ||
          request.auth.token.email == 'Mypassion9182@gmail.com' ||
          request.auth.token.email == 'Admin@popcornplay.com' ||
          request.auth.token.email.matches('(?i)^mdikhlas098@gmail\\.com$') ||
          request.auth.token.email.matches('(?i)^admin@popcornplay\\.com$') ||
          request.auth.token.email.matches('(?i)^mypassion9182@gmail\\.com$')
        )) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('email', '') == 'mdikhlas098@gmail.com' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('email', '') == 'mypassion9182@gmail.com' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('email', '') == 'admin@popcornplay.com' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('email', '').matches('(?i)^mdikhlas098@gmail\\.com$') ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('email', '').matches('(?i)^admin@popcornplay\\.com$') ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('email', '').matches('(?i)^mypassion9182@gmail\\.com$')
        )) ||
        (exists(/databases/$(database)/documents/app_settings/config) && 'email' in request.auth.token &&
         request.auth.token.email == get(/databases/$(database)/documents/app_settings/config).data.get('adminEmail', ''))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isLocalUser(id) {
      return id is string && id.size() >= 10 && id.matches('^local-usr-.*');
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. SCHEMA INTEGRITY VALIDATION BUILDERS
    function isValidUserProfile(data) {
      return (!('uid' in data) || data.uid is string)
          && (!('name' in data) || data.name is string)
          && (!('email' in data) || data.email is string)
          && (!('isPremium' in data) || data.isPremium is bool)
          && (!('favorites' in data) || data.favorites is list);
    }

    function isValidAppSettings(data) {
      return (!('appName' in data) || data.appName is string)
          && (!('adultPin' in data) || data.adultPin is string)
          && (!('supportActive' in data) || data.supportActive is bool)
          && (!('bkash' in data) || data.bkash is string)
          && (!('nagad' in data) || data.nagad is string)
          && (!('bank' in data) || data.bank is string);
    }

    function isValidContentItem(data) {
      return (!('id' in data) || data.id is string)
          && (!('title' in data) || (data.title is string && data.title.size() <= 128))
          && (!('coverUrl' in data) || data.coverUrl is string)
          && (!('videoUrl' in data) || data.videoUrl is string)
          && (!('tags' in data) || data.tags is list)
          && (!('category' in data) || data.category is string)
          && (!('isPremium' in data) || data.isPremium is bool)
          && (!('isAdult' in data) || data.isAdult is bool)
          && (!('schedule' in data) || data.schedule is string)
          && (!('description' in data) || data.description is string)
          && (!('rating' in data) || (data.rating is int || data.rating is float));
    }

    function isValidPaymentRequest(data) {
      return (!('id' in data) || data.id is string)
          && (!('userId' in data) || data.userId is string)
          && (!('userName' in data) || data.userName is string)
          && (!('userEmail' in data) || data.userEmail is string)
          && (!('method' in data) || data.method is string)
          && (!('senderNumber' in data) || (data.senderNumber is string && data.senderNumber.size() <= 100))
          && (!('transactionId' in data) || (data.transactionId is string && data.transactionId.size() <= 200))
          && (!('amount' in data) || (data.amount is int || data.amount is float))
          && (!('timestamp' in data) || data.timestamp is string)
          && (!('status' in data) || (data.status is string && data.status in ['pending', 'approved', 'rejected']));
    }

    function isValidNotificationItem(data) {
      return (!('id' in data) || data.id is string)
          && (!('msg' in data) || (data.msg is string && data.msg.size() <= 1000))
          && (!('time' in data) || data.time is string);
    }

    // Support Session checking inside helper
    function isValidSupportSession(data) {
      return 'messages' in data
          && (!('userId' in data) || data.userId is string)
          && (!('userName' in data) || data.userName is string)
          && (!('userEmail' in data) || data.userEmail is string)
          && data.messages is list
          && (!('lastUpdated' in data) || data.lastUpdated is string);
    }

    function isValidFeedbackItem(data) {
      return (!('id' in data) || data.id is string)
          && (!('userId' in data) || data.userId is string)
          && (!('userName' in data) || data.userName is string)
          && (!('userEmail' in data) || data.userEmail is string)
          && (!('type' in data) || (data.type is string && data.type in ['suggestion', 'bug', 'other']))
          && (!('message' in data) || (data.message is string && data.message.size() <= 3000))
          && (!('timestamp' in data) || data.timestamp is string)
          && (!('status' in data) || (data.status is string && data.status in ['pending', 'reviewed', 'resolved']));
    }

    // 4. COLLECTION ROUTING & ACTIONS
    
    // User Profiles
    match /users/{userId} {
      allow get: if (isSignedIn() && (isOwner(userId) || isAdmin())) || isLocalUser(userId);
      allow create: if ( (isSignedIn() && isOwner(userId)) || isLocalUser(userId) ) 
                     && 'uid' in incoming() && 'name' in incoming() && 'email' in incoming() && 'isPremium' in incoming() && 'favorites' in incoming()
                     && isValidUserProfile(incoming()) 
                     && (incoming().isPremium == false || isAdmin()) 
                     && (!('isAdmin' in incoming()) || incoming().isAdmin == false || isAdmin());
      allow update: if isValidUserProfile(incoming()) && (
                       isAdmin() || 
                       ( ( (isSignedIn() && isOwner(userId)) || isLocalUser(userId) ) &&
                         incoming().get('isPremium', false) == existing().get('isPremium', false) &&
                         (!('isAdmin' in incoming()) || incoming().get('isAdmin', false) == existing().get('isAdmin', false)) )
                     );
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }

    // Global Brand Configuration
    match /app_settings/{documentId} {
      allow get, list: if true;
      allow create: if isAdmin() && 'appName' in incoming() && 'adultPin' in incoming() && 'supportActive' in incoming() && 'bkash' in incoming() && 'nagad' in incoming() && 'bank' in incoming() && isValidAppSettings(incoming());
      allow update: if isAdmin() && isValidAppSettings(incoming());
      allow delete: if isAdmin();
    }

    // Media Catalog items
    match /content/{contentId} {
      allow get, list: if true;
      allow create: if isAdmin() && isValidContentItem(incoming()) && isValidId(contentId);
      allow delete: if isAdmin() && isValidId(contentId);
      allow update: if (isValidContentItem(incoming()) && isAdmin()) || (
                      incoming().title == existing().title &&
                      incoming().coverUrl == existing().coverUrl &&
                      incoming().videoUrl == existing().videoUrl &&
                      incoming().category == existing().category &&
                      incoming().isPremium == existing().isPremium &&
                      incoming().isAdult == existing().isAdult
                    );

      match /ratings/{userId} {
        allow read: if true;
        allow write: if ((isSignedIn() && isOwner(userId)) || isLocalUser(userId)) &&
                       incoming().keys().hasAll(['userId', 'rating', 'timestamp']) &&
                       incoming().userId == userId &&
                       (incoming().rating is int || incoming().rating is float) &&
                       incoming().rating >= 1 &&
                       incoming().rating <= 5 &&
                       (incoming().timestamp is int || incoming().timestamp is float);
      }
    }

    // Billing Subscriptions
    match /payments/{paymentId} {
      allow get: if (isSignedIn() && (isOwner(existing().userId) || isAdmin())) || isLocalUser(existing().userId);
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid) || isLocalUser(resource.data.userId);
      allow create: if ( (isSignedIn() && (isOwner(incoming().userId) || isAdmin())) || isLocalUser(incoming().userId) ) 
                     && incoming().status == 'pending' 
                     && isValidPaymentRequest(incoming()) 
                     && isValidId(paymentId);
      allow update: if isValidPaymentRequest(incoming()) && isAdmin();
      allow delete: if isAdmin();
    }

    // Broadcaster notifications
    match /notifications/{notificationId} {
      allow get, list: if true;
      allow create, update: if isAdmin() && isValidNotificationItem(incoming()) && isValidId(notificationId);
      allow delete: if isAdmin() && isValidId(notificationId);
    }

    // Noticeboard Notices
    match /notices/{noticeId} {
      allow get, list: if true;
      allow write: if isAdmin() && isValidId(noticeId);
    }

    // Live Support Customer Help-desks
    match /live_support/{userId} {
      allow get: if (isSignedIn() && (isOwner(userId) || isAdmin())) || isLocalUser(userId);
      allow list: if isAdmin();
      allow create: if ( (isSignedIn() && isOwner(userId)) || isLocalUser(userId) ) && isValidSupportSession(incoming()) && isValidId(userId);
      allow update: if ( (isSignedIn() && isOwner(userId)) || isLocalUser(userId) || isAdmin() ) && isValidSupportSession(incoming());
      allow delete: if (isSignedIn() && (isOwner(userId) || isAdmin())) || isLocalUser(userId);
    }

    // User Feedback & Suggestions CMS
    match /feedback/{feedbackId} {
      allow get: if (isSignedIn() && (isOwner(existing().userId) || isAdmin())) || isLocalUser(existing().userId);
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid) || isLocalUser(resource.data.userId);
      allow create: if ( (isSignedIn() && isOwner(incoming().userId)) || isLocalUser(incoming().userId) ) 
                     && incoming().status == 'pending' 
                     && isValidFeedbackItem(incoming()) 
                     && isValidId(feedbackId);
      allow update: if isAdmin() && isValidFeedbackItem(incoming());
      allow delete: if isAdmin();
    }

  }
}
